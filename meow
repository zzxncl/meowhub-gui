-- ============================================================
-- BILLBOARD TAG — stamp OUR character so others can detect us.
-- The BillboardGui is parented to Head so it persists and
-- other clients' "Show others using script" scan can find it.
-- ============================================================
local function stampCharacter(char)
    if not char then return end
    local head = char:WaitForChild("Head", 5)
    if not head then return end
    -- Set the attribute that other clients check
    char:SetAttribute(MEOW_ATTR_KEY, MEOW_ATTR_VAL)
    -- Also place the billboard on our OWN head
    if head:FindFirstChild(MEOW_TAG_NAME) then return end
    local bb = Instance.new("BillboardGui")
    bb.Name      = MEOW_TAG_NAME
    bb.Size      = UDim2.new(0, 60, 0, 60)
    bb.StudsOffset = Vector3.new(0, 3.5, 0)
    bb.AlwaysOnTop = true
    bb.Adornee   = head
    bb.Parent    = head
    local img = Instance.new("ImageLabel")
    img.Size               = UDim2.new(1, 0, 1, 0)
    img.BackgroundTransparency = 1
    img.Image              = MEOW_IMAGE_ID
    img.ScaleType          = Enum.ScaleType.Fit
    img.Parent             = bb
end

if lp.Character then task.spawn(stampCharacter, lp.Character) end
lp.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    stampCharacter(char)
end)

