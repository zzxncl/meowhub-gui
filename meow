local function makeTabBtn(name, order)
    local btn=Instance.new("TextButton"); btn.Size=UDim2.new(1,0,0,32); btn.BackgroundTransparency=1
    btn.Text=""; btn.LayoutOrder=order; btn.Parent=SidebarList
