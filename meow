    return btn,bg,bgs,lbl
end

local function switchTab(targetName)
    for n,frame in pairs(tabFrames) do frame.Visible=(n==targetName) end
    for n,data in pairs(tabButtons) do
        local active=(n==targetName)
        data.bg.BackgroundTransparency=active and 0 or 1
        data.bg.BackgroundColor3=Color3.fromRGB(28,26,46)
        data.stroke.Transparency=active and 0 or 1
        data.label.TextColor3=active and Color3.fromRGB(184,176,255) or Color3.fromRGB(86,86,104)
    end
end

for i,tabName in ipairs({"Main","Player","Util","Misc","Settings"}) do
    local frame=makeScrollFrame(); tabFrames[tabName]=frame
    local btn,bg,stroke,lbl=makeTabBtn(tabName,i)
    tabButtons[tabName]={bg=bg,stroke=stroke,label=lbl}
    btn.MouseButton1Click:Connect(function() switchTab(tabName) end)
    btn.MouseEnter:Connect(function()
        if tabFrames[tabName].Visible then return end
        bg.BackgroundTransparency=0.6; bg.BackgroundColor3=Color3.fromRGB(23,23,30); lbl.TextColor3=Color3.fromRGB(144,144,170)
    end)
    btn.MouseLeave:Connect(function()
        if tabFrames[tabName].Visible then return end
        bg.BackgroundTransparency=1; lbl.TextColor3=Color3.fromRGB(86,86,104)
    end)
end

