-- ============================================================
-- EXECUTOR DETECTION
-- Checks globals that each popular executor injects.
-- Falls back to "Unknown Executor" if none match.
-- ============================================================
local function detectExecutor()
    -- Synapse X / Synapse V3
    if syn or (typeof(syn) == "table") then return "Synapse X" end
    -- KRNL
    if KRNL_LOADED or krnl then return "KRNL" end
    -- Fluxus
    if fluxus or fluxus_loaded then return "Fluxus" end
    -- Script-Ware
    if ScriptWare or scriptware then return "Script-Ware" end
    -- Oxygen U
    if oxygen or oxygenU or OXYGEN then return "Oxygen U" end
    -- Arceus X / Mobile
    if ARCEUS_X or arceus then return "Arceus X" end
    -- Delta (mobile)
    if Delta or delta_execute then return "Delta" end
    -- Codex
    if CODEX or codex then return "Codex" end
    -- Wave
    if Wave or wave_loaded then return "Wave" end
    -- JJSploit
    if JJSploit or jjsploit then return "JJSploit" end
    -- Executor global present but unrecognised
    if getexecutorname and pcall(getexecutorname) then
        local ok, name = pcall(getexecutorname)
        if ok and name then return tostring(name) end
    end
    -- identifyexecutor (Synapse V3 / newer)
    if identifyexecutor then
        local ok, name = pcall(identifyexecutor)
        if ok and name then return tostring(name) end
    end
    return "Unknown Executor"
end

local executorName = detectExecutor()

