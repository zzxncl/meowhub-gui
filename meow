-- MISC — "show others using script" only
-- HOW IT WORKS:
--   When you execute this script, stampCharacter() (top of file) sets
--   char:SetAttribute("MeowHubUser","v2.4") on YOUR character.
--   When the toggle is ON, we scan every player's character every second.
--   If their character has that attribute we place the BillboardGui above
--   their head.  No attribute = not running MeowHub = no tag.
local miscFrame=tabFrames["Misc"]
makeSection(miscFrame, T.social_section, 1)

local showUsersEnabled=false
local tagConns={}
local taggedChars={}   -- [character] = BillboardGui

local function placeCatTag(char)
    if taggedChars[char] then return end
    local head=char:FindFirstChild("Head")
    if not head then return end
    if head:FindFirstChild(MEOW_TAG_NAME) then return end
    local bb=Instance.new("BillboardGui")
    bb.Name=MEOW_TAG_NAME; bb.Size=UDim2.new(0,60,0,60); bb.StudsOffset=Vector3.new(0,3.5,0)
    bb.AlwaysOnTop=true; bb.Adornee=head; bb.Parent=head
    local img=Instance.new("ImageLabel"); img.Size=UDim2.new(1,0,1,0); img.BackgroundTransparency=1
    img.Image=MEOW_IMAGE_ID; img.ScaleType=Enum.ScaleType.Fit; img.Parent=bb
    taggedChars[char]=bb
end

local function removeCatTag(char)
    if taggedChars[char] then taggedChars[char]:Destroy(); taggedChars[char]=nil end
    local head=char:FindFirstChild("Head")
    if head then local t=head:FindFirstChild(MEOW_TAG_NAME); if t then t:Destroy() end end
end

local function isMeowUser(char)
    return char:GetAttribute(MEOW_ATTR_KEY)==MEOW_ATTR_VAL
end

local function scanPlayers()
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=lp then  -- don't double-tag ourselves
            local char=p.Character
            if char and isMeowUser(char) then
                placeCatTag(char)
            elseif char and taggedChars[char] then
                removeCatTag(char)
            end
        end
    end
end

makeToggle(miscFrame, T.show_users, T.show_users_d, 2, function(v)
    showUsersEnabled=v
    if v then
        -- Immediate scan
        scanPlayers()
        -- Periodic re-scan (catches late attribute set + new spawns)
        local loopConn=RunService.Heartbeat:Connect(function()
            if not showUsersEnabled then return end
            scanPlayers()
        end)
        table.insert(tagConns, loopConn)
        -- Watch new players
        local joinConn=Players.PlayerAdded:Connect(function(p)
            p.CharacterAdded:Connect(function(char)
                task.wait(1)   -- give their script time to stamp the attribute
                if showUsersEnabled and isMeowUser(char) then
                    placeCatTag(char)
                end
            end)
        end)
        table.insert(tagConns, joinConn)
    else
        for _,c in ipairs(tagConns) do c:Disconnect() end
        tagConns={}
        -- Remove all tags
        for _,p in ipairs(Players:GetPlayers()) do
            if p.Character then removeCatTag(p.Character) end
        end
        taggedChars={}
    end
end)

